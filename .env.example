# Jarvix reads API configuration from your shell environment only.
# Do not commit real secrets.
JARVIX_AI_PROVIDER=gemini

OPENAI_API_KEY=

GEMINI_API_KEY=
# GOOGLE_API_KEY also works for Gemini if you prefer Google's standard env name.

# OpenAI default: gpt-5.5
# Gemini default: gemini-3.5-flash
JARVIX_MODEL=gemini-3.5-flash
